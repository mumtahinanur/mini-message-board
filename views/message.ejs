<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Message from <%= message.user %></title>
</head>
<body>
  <h1>Message Details</h1>
  <p><strong>From:</strong> <%= message.user %></p>
  <p><strong>Message:</strong> <%= message.text %></p>
  <p><strong>Sent:</strong> <%= message.added.toDateString() %></p>

  <a href="/">← Back to board</a>
</body>
</html>
