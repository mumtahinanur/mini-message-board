<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message from <%= message.author %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>Message Details</h1>
  <p><strong>From:</strong> <%= message.author %></p>
  <p><strong>Message:</strong> <%= message.text %></p>
  <p><strong>Sent:</strong> <%= message.added_at.toDateString() %></p>

  <a href="/" class="back-link">← Back to board</a>
</body>
</html>
