<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>New Message</title>
</head>
<body>
  <h1>New Message</h1>

  <form method="POST" action="/new">
    <label>
      Your name:
      <input type="text" name="user" required>
    </label>
    <br>
    <label>
      Message:
      <input type="text" name="text" required>
    </label>
    <br>
    <button type="submit">Send</button>
  </form>
  
  <a href="/">← Back</a>
</body>
</html>
